SceneSettings:
  Storage:
    ExpectedEntities: 1024
    ExpectedTransforms: 768
    ExpectedRenderables: 512
    ExpectedCullingComponents: 512
    ExpectedStaticEntities: 256
    PreallocatedTransformPages: 0
    PreallocatedTagPages: 0
    RenderPacketReserve: 512
    VisibleEntityReserve: 512
    StaticBatchReserve: 64
    AllowRuntimeGrowth: true
    LogCapacityGrowth: true
Entities:
  - Entity: 1
    Components:
      - Component: NameComponent
        Name: Field
      - Component: TransformComponent
