Entities:
  - LocalID: 0
    Components:
      - Component: NameComponent
        Name: Ball
      - Component: TransformComponent
        Position:
          x: 0
          y: 0
          z: 0
        Rotation:
          - 0
          - 0
          - 0
          - 1
        Scale:
          x: 2.5
          y: 2.4999969
          z: 2.4999969
        Parent: 0
      - Component: ColliderComponent
        isDynamic: false
        autoMass: true
        Mass: 0
        colliders:
          - type: 1
            size: [1, 1, 1]
            offset: [0, 0, 0]
            rotationOffset: [0, 0, 0]
            radius: 0.200000003
            height: 1
            staticFriction: 0
            dynamicFriction: 0
            restitution: 0
            collisionLayer: 0
            lockRotX: false
            lockRotY: false
            lockRotZ: false
            isTrigger: false
            boneName: ""
      - Component: MaterialComponent
        ShaderID: 1
        Material:
          BaseColor:
            x: 1
            y: 1
            z: 1
            w: 1
          Metallic: 0
          Roughness: 0
          AO: 0
          EmissiveColor:
            x: 0
            y: 0
            z: 0
          EmissiveIntensity: 0
          UseDiffuseTexture: true
          UseNormalTexture: true
          UseEnvironmentMap: false
      - Component: TextureComponent
        UV_Slice_X: 1
        UV_Slice_Y: 1
        AnimationNum: 0
      - Component: ModelRendererComponent
        FilePath: Asset/Model\ball.fbx
        isBlender: false
        AnimationTime: 0