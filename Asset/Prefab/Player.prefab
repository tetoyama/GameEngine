Entities:
  - LocalID: 0
    Components:
      - Component: NameComponent
        Name: Player
      - Component: TransformComponent
        Position:
          x: 2.20148492
          y: -2.04003527e-07
          z: 12.0978708
        Rotation:
          - 1.23091132e-16
          - 0.932829201
          - 9.51925984e-18
          - -0.360318959
        Scale:
          x: 0.0100000165
          y: 0.00999999978
          z: 0.0100000165
        Parent: 0
      - Component: ColliderComponent
        isDynamic: true
        autoMass: true
        Mass: 1
        colliders:
          - type: 2
            size: [1, 1, 1]
            offset: [0, 75, 0]
            rotationOffset: [0, 0, 90]
            radius: 25
            height: 100
            staticFriction: 0
            dynamicFriction: 0
            restitution: 0
            collisionLayer: 2
            lockRotX: true
            lockRotY: true
            lockRotZ: true
            isTrigger: false
            boneName: ""
          - type: 1
            size: [1, 1, 1]
            offset: [0, 0, 0]
            rotationOffset: [0, 0, 0]
            radius: 14.3999996
            height: 1
            staticFriction: 0
            dynamicFriction: 0
            restitution: 0
            collisionLayer: 2
            lockRotX: true
            lockRotY: true
            lockRotZ: true
            isTrigger: true
            boneName: mixamorig:LeftHand
      - Component: MaterialComponent
        ShaderID: 1
        Material:
          BaseColor:
            x: 1
            y: 1
            z: 1
            w: 1
          Metallic: 0
          Roughness: 0
          AO: 0
          EmissiveColor:
            x: 0
            y: 0
            z: 0
          EmissiveIntensity: 0
          UseDiffuseTexture: true
          UseNormalTexture: true
      - Component: ModelRendererComponent
        FilePath: Asset\Model\Y Bot.fbx
        isBlender: false
        AnimationTime: 3436.77515
        Animations:
          Idle: Asset\Model\Akai_Idle.fbx
          Run: Asset\Model\Akai_Run.fbx
      - Component: CharacterController
        moveSpeed: 5
        dashMultiplier: 2.5
        jumpPower: 5
        accel: 12
        rotateSpeed: 8
        groundRayLength: 0.300000012
        slopeLimit: 45
        gravity: 9
        idleAnimFile: Asset/Model/Akai_Idle.fbx
        runAnimFile: Asset/Model/Akai_Run.fbx
        jumpUpAnimFile: Asset/Model/Jumping Up.fbx
        jumpDownAnimFile: Asset/Model/Jumping Down.fbx
        SelfLayerBit: 2
